# OKX Facilitator credentials
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Your receiving wallet address on X Layer
PAY_TO_ADDRESS=

# OpenRouter API key
OPENROUTER_API_KEY=sk-or-...

# Server port
PORT=4002

# Payment scheme: "aggr_deferred" (batch, recommended) or "exact" (one-time)
OKCLAWROUTER_PAYMENT_SCHEME=aggr_deferred

# (Optional) Site URL sent to OpenRouter as HTTP-Referer
# SITE_URL=https://your-domain.com

# (Optional) Override OpenRouter API base URL
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
